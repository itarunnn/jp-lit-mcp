{
  "name": "jp-lit-mcp",
  "version": "0.1.9",
  "private": false,
  "license": "MIT",
  "type": "module",
  "description": "MCP server and Skills for Japanese literature and humanities research across NDL, CiNii, J-STAGE, IRDB, and related sources",
  "bin": {
    "jp-lit-mcp": "dist/src/index.js",
    "jp-lit-mcp-install-skills": "scripts/install-skills.mjs"
  },
  "files": [
    "dist/",
    "docs/",
    "skills/",
    "scripts/install-skills.mjs",
    "scripts/install-skills.ps1",
    "scripts/install-skills.sh",
    "README.md",
    "LICENSE",
    "mcp-config.example.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build",
    "smoke:mcp": "tsx scripts/smoke-mcp.ts",
    "smoke:mcp:live-matrix": "cross-env SMOKE_LIVE_MATRIX=1 SMOKE_LIVE=1 tsx scripts/smoke-mcp.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "skills:install": "node scripts/install-skills.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fast-xml-parser": "^5.7.1",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "cross-env": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
